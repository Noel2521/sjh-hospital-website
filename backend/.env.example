# ════════════════════════════════════════════
# St. Joseph's Hospital — Backend Environment
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to GitHub.
# ════════════════════════════════════════════

# ── Database ──
# Get this from Railway or Supabase dashboard after creating a PostgreSQL instance
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/sjh_hospital?schema=public"

# ── Auth ──
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# ── AI (Anthropic) ──
# Create an account at console.anthropic.com using the hospital email
# Generate an API key and paste it here
ANTHROPIC_API_KEY="sk-ant-..."

# ── App ──
PORT=4000
FRONTEND_URL="https://sjhmysuru.com"

# ── Email (Resend) ──
# Sign up at resend.com with hospital email, create an API key
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@sjhmysuru.com"
ADMIN_EMAIL="admin@sjhmysuru.com"
